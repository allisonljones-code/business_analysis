              <calculation class='tableau' formula='//Product Single Select&#13;&#10;IF COUNTD([Product Name]) = 1 THEN ATTR([Product Name])&#13;&#10;ELSEIF COUNTD([Sub-Category]) = 1 THEN ATTR([Sub-Category])&#13;&#10;ELSEIF COUNTD([Category]) = 1 THEN ATTR([Category])&#13;&#10;ELSE &quot;&quot;&#13;&#10;END' />
            </column>
