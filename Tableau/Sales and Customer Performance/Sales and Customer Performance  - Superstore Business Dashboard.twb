      <column caption='Metric Type_Value_SelectYear' datatype='real' hidden='true' name='[Metric Type_Value_PY (copy)_1837340921483271]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='//Metric Type_Value_SelectYear&#13;&#10;CASE [Parameters].[Parameter 4]&#13;&#10;WHEN &quot;Orders&quot;&#13;&#10;    THEN SUM([Calculation_3148860574044459018])&#13;&#10;WHEN &quot;Shipments&quot;&#13;&#10;    THEN SUM([dr.OrderValue_selectyear (copy)_3148860574044897292])&#13;&#10;WHEN &quot;Profit&quot;&#13;&#10;    THEN [Calculation_3776549772490334213]&#13;&#10;END' />
      </column>
      <column caption='Metric Type_Value' datatype='real' name='[Metric Type_Value_PY (copy)_3376382666321920]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='//Metric Type_Value&#13;&#10;CASE [Parameters].[Parameter 4]&#13;&#10;WHEN &quot;Orders&quot;&#13;&#10;    THEN SUM([Calculation_3148860574040231938])&#13;&#10;WHEN &quot;Shipments&quot;&#13;&#10;    THEN SUM([Order Value (copy)_3148860574040989699])&#13;&#10;WHEN &quot;Profit&quot;&#13;&#10;    THEN (SUM([Profit]) / SUM([Order Value (copy)_3148860574040989699]))*100&#13;&#10;END' />
