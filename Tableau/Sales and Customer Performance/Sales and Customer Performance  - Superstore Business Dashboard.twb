    <worksheet name='Pareto_Top Customers'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true'><![CDATA[<[federated.0gngkf21f9jk22164o74h1biee2z].[none:Calculation_2515465414193154:nk]> ]]></run>
            <run>Contribution by Customer (Pareto)

</run>
            <run fontcolor='#000000' fontsize='10'>The Pareto analysis shows not only that </run>
            <run bold='true' fontcolor='#000000' fontsize='10'>profit</run>
            <run fontcolor='#000000' fontsize='10'> is more </run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontsize='10'>concentrated than orders and shipments, but also that </run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontsize='10'>the</run>
            <run bold='true' fontcolor='#000000' fontsize='10'> customers contributing to each are different</run>
            <run fontcolor='#000000' fontsize='10'>.</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontsize='10' italic='true'>* high/low above or below customer average</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Sample Superstore Data' name='federated.0gngkf21f9jk22164o74h1biee2z' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='N Customers' datatype='integer' name='[Parameter 1]' param-domain-type='range' role='measure' type='quantitative' value='10'>
              <calculation class='tableau' formula='10' />
              <range granularity='5' max='20' min='5' />
            </column>
            <column caption='Metric Type' datatype='string' name='[Parameter 4]' param-domain-type='list' role='measure' type='nominal' value='&quot;Profit&quot;'>
              <calculation class='tableau' formula='&quot;Profit&quot;' />
            </column>
            <column caption='Annotation Pareto % Parameter' datatype='real' name='[Parameter 6]' param-domain-type='any' role='measure' type='quantitative' value='0.4'>
              <calculation class='tableau' formula='0.4' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.0gngkf21f9jk22164o74h1biee2z'>
            <column caption='Avg Customer Profit_Fixed' datatype='real' name='[Avg Customer Orders_Fixed (copy)_0705670184009739]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='// Avg Customer Profit&#13;&#10;{ FIXED : AVG({ FIXED [Customer Name] : SUM([Profit]) }) }' />
            </column>
            <column caption='Pareto Annotation_TopN_%' datatype='string' name='[Calculation_0705669806206977]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_2515465420701701] = [Pareto Annotation_TopN_% (copy)_0705669807325188] THEN&#13;&#10;STR(ROUND([Calculation_3376382674653195]*100,0)) + &quot;%&quot;&#13;&#10;END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Customer Orders_fixed' datatype='real' name='[Calculation_0705670183247880]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='// Customer Orders_fixed&#13;&#10;{ FIXED [Customer Name] : SUM([Calculation_3148860574040231938]) }' />
            </column>
            <column caption='Customer Profit_fixed' datatype='real' name='[Calculation_0705670183350281]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='// Customer Profit_fixed&#13;&#10;{ FIXED [Customer Name] : SUM([Profit]) }' />
            </column>
            <column caption='Avg Customer Orders_Fixed' datatype='real' name='[Calculation_0705670183444490]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='// Avg Customer Orders&#13;&#10;{ FIXED : AVG({ FIXED [Customer Name] : SUM([Calculation_3148860574040231938]) }) }' />
            </column>
            <column caption='High Orders' datatype='boolean' name='[Calculation_0705670184140812]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='// High Orders&#13;&#10;[Calculation_0705670183247880] &gt;= [Calculation_0705670183444490]' />
              <aliases>
                <alias key='false' value='Low' />
                <alias key='true' value='High' />
              </aliases>
            </column>
            <column caption='Zero Values_TF' datatype='boolean' name='[Calculation_0705670185668622]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='CASE [Calculation_3148860574039736320] &#13;&#10;    WHEN &quot;Orders&quot; THEN &#13;&#10;    IF ISNULL([Calculation_3148860574040231938]) THEN TRUE ELSE FALSE END&#13;&#10;    WHEN &quot;Profit&quot; THEN &#13;&#10;    IF ISNULL([Calculation_3148860574040231938]) THEN TRUE ELSE FALSE END&#13;&#10;ELSE FALSE END' />
            </column>
            <column caption='Top N Color' datatype='string' name='[Calculation_2515465413718017]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF RANK_UNIQUE([Metric Type_Value (copy)_3376382675271693], &apos;desc&apos;) &lt;= [Parameters].[Parameter 1]&#13;&#10;THEN &quot;Top N&quot;&#13;&#10;ELSE &quot;Other&quot;&#13;&#10;END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Metric Type_Label' datatype='string' name='[Calculation_2515465414193154]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='//Metric Type_Label&#13;&#10;CASE [Parameters].[Parameter 4]&#13;&#10;    WHEN &quot;Orders&quot; THEN &quot;Order&quot;&#13;&#10;    WHEN &quot;Shipments&quot; THEN &quot;Shipment&quot;&#13;&#10;    WHEN &quot;Profit&quot; THEN &quot;Profit&quot;&#13;&#10;END' />
            </column>
            <column caption='Index' datatype='integer' name='[Calculation_2515465420701701]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='Index()'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='DataType' datatype='string' name='[Calculation_3148860574039736320]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Table Name] = &quot;Orders&quot; THEN &quot;Orders&quot;&#13;&#10;ELSEIF [Table Name] = &quot;Orders1&quot; THEN &quot;Shipments&quot;&#13;&#10;END' />
            </column>
            <column caption='Record Date' datatype='date' name='[Calculation_3148860574040068097]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='CASE [Calculation_3148860574039736320]&#13;&#10;WHEN &quot;Orders&quot; THEN [Order Date]&#13;&#10;WHEN &quot;Shipments&quot; THEN [Ship Date]&#13;&#10;END' />
            </column>
            <column caption='Order Value' datatype='real' default-format='c&quot;$&quot;#,##0;(&quot;$&quot;#,##0)' name='[Calculation_3148860574040231938]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [Calculation_3148860574039736320] &#13;&#10;WHEN &quot;Orders&quot; THEN [Sales]&#13;&#10;END' />
            </column>
            <column caption='Metric Type_Pareto %' datatype='real' default-format='p0%' name='[Calculation_3376382674653195]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='//Metric Type_Pareto % : computed along table (across)&#13;&#10;RUNNING_SUM([Metric Type_Value (copy)_3376382675271693]) / WINDOW_SUM([Metric Type_Value (copy)_3376382675271693])'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column datatype='string' name='[Category]' role='dimension' type='nominal' />
            <column datatype='string' name='[Customer Name]' role='dimension' type='nominal' />
            <column caption='High Profit' datatype='boolean' name='[High Orders (copy)_0705670184325133]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='// High Profit&#13;&#10;[Calculation_0705670183350281] &gt;= [Avg Customer Orders_Fixed (copy)_0705670184009739]' />
              <aliases>
                <alias key='false' value='Low' />
                <alias key='true' value='High' />
              </aliases>
            </column>
            <column caption='Metric Type_Prefix_2_3' datatype='string' name='[Metric Type_Prefix (copy)_2515465412427776]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='//Metric Type_Value_PY&#13;&#10;CASE [Parameters].[Parameter 4]&#13;&#10;WHEN &quot;Orders&quot; THEN &quot;$&quot;&#13;&#10;WHEN &quot;Shipments&quot; THEN &quot;$&quot;&#13;&#10;WHEN &quot;Profit&quot; THEN &quot;$&quot;&#13;&#10;END' />
            </column>
            <column caption='Metric Type_Value_2' datatype='real' name='[Metric Type_Value (copy)_3376382675271693]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='//Metric Type_Value_2&#13;&#10;CASE [Parameters].[Parameter 4]&#13;&#10;WHEN &quot;Orders&quot;&#13;&#10;    THEN SUM([Calculation_3148860574040231938])&#13;&#10;WHEN &quot;Shipments&quot;&#13;&#10;    THEN SUM([Order Value (copy)_3148860574040989699])&#13;&#10;WHEN &quot;Profit&quot;&#13;&#10;    THEN IF SUM([Profit]) &gt; 0 THEN SUM([Profit])&#13;&#10;    ELSE 0 END // clip negative profit&#13;&#10;END' />
            </column>
            <column datatype='date' name='[Order Date]' role='dimension' type='ordinal' />
            <column caption='Shipments Value' datatype='real' default-format='c&quot;$&quot;#,##0;(&quot;$&quot;#,##0)' name='[Order Value (copy)_3148860574040989699]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [Calculation_3148860574039736320] &#13;&#10;WHEN &quot;Shipments&quot; THEN [Sales]&#13;&#10;END' />
            </column>
            <column caption='Pareto Annotation_MetricType_text' datatype='string' name='[Pareto Annotation_Customers_text (copy)_0705669808824325]' role='measure' type='nominal'>
              <calculation class='tableau' formula='//IF INDEX() = [Annotation Index Parameter] THEN&#13;&#10;IF [Calculation_2515465420701701] = [Pareto Annotation_TopN_% (copy)_0705669807325188] THEN&#13;&#10;&quot; of &quot; + [Parameters].[Parameter 4]&#13;&#10;END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Pareto Annotation_TopN_text' datatype='string' name='[Pareto Annotation_TopN (copy) (copy)_0705669806841859]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_2515465420701701] = [Pareto Annotation_TopN_% (copy)_0705669807325188] THEN &quot;Top &quot; &#13;&#10;END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Pareto Annotation_Customers_text' datatype='string' name='[Pareto Annotation_TopN (copy)_0705669806829570]' role='measure' type='nominal'>
              <calculation class='tableau' formula='//IF INDEX() = [Annotation Index Parameter] THEN&#13;&#10;IF [Calculation_2515465420701701] = [Pareto Annotation_TopN_% (copy)_0705669807325188] THEN&#13;&#10;&quot; Customers&quot;&#13;&#10;END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Pareto Annotation_Index' datatype='integer' name='[Pareto Annotation_TopN_% (copy)_0705669807325188]' role='measure' type='ordinal'>
              <calculation class='tableau' formula='//IF INDEX() = [Annotation Index Parameter] THEN&#13;&#10;//[Annotation Index Parameter]&#13;&#10;IF [Calculation_3376382674653195] &gt;= [Parameters].[Parameter 6]&#13;&#10;AND LOOKUP([Calculation_3376382674653195], -1) &lt; [Parameters].[Parameter 6]&#13;&#10;THEN INDEX()&#13;&#10;END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Pareto Annotation_account_for_text' datatype='string' name='[Pareto Annotation_TopN_% (copy)_0705669809795079]' role='measure' type='nominal'>
              <calculation class='tableau' formula='//IF INDEX() = [Annotation Index Parameter] THEN&#13;&#10;IF [Calculation_2515465420701701] = [Pareto Annotation_TopN_% (copy)_0705669807325188] THEN&#13;&#10;&quot; account for &quot;&#13;&#10;END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
